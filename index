  .row{display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin-top:20px}

  /* ---- vault 1 ---- */
  .timer{display:flex;align-items:center;gap:18px;margin:18px 0 8px}
  .ringwrap{position:relative;width:84px;height:84px;flex:0 0 84px}
  .ringwrap svg{transform:rotate(-90deg)}
  .ringwrap .num{position:absolute;inset:0;display:grid;place-items:center;font-size:26px;font-weight:700;color:var(--gold);font-family:'Space Mono'}
  .abstract{
    font-family:'Special Elite',serif;font-size:15.5px;line-height:1.85;color:var(--ink);
    border-left:3px solid var(--gold-dim);padding:4px 0 4px 18px;margin:12px 0;transition:.6s;
  }
  .abstract.locked{filter:blur(4px) grayscale(.7);opacity:.32;user-select:none}
  .lockedstamp{display:none;text-align:center;color:var(--red);font-family:'Bebas Neue';letter-spacing:4px;
    border:2px solid var(--red);padding:6px;border-radius:3px;transform:rotate(-3deg);margin:10px auto;max-width:280px;font-size:18px}
  .lockedstamp.show{display:block;animation:stamp .3s ease both}
  @keyframes stamp{from{transform:scale(1.6) rotate(-3deg);opacity:0}to{transform:scale(1) rotate(-3deg);opacity:1}}

  .q{margin:16px 0;border-top:1px dashed var(--line);padding-top:14px}
  .q p{font-size:14px;margin-bottom:10px}
  .q p b{color:var(--gold-soft)}
  .opt{display:block;width:100%;text-align:left;border:1px solid var(--line);background:var(--panel);
    color:var(--ink);padding:10px 14px;border-radius:3px;margin:7px 0;cursor:pointer;font-family:'Space Mono';font-size:13px;transition:.15s}
  .opt:hover{border-color:var(--gold-dim)}
  .opt.sel{border-color:var(--gold);background:rgba(244,183,64,.1)}
  .opt.correct{border-color:var(--cyan);background:rgba(52,211,166,.12);color:#bff3e1}
  .opt.wrong{border-color:var(--red);background:rgba(225,86,64,.12)}
  .opt:disabled{cursor:default}

  /* ---- vault 2 ---- */
  .tray{display:flex;flex-wrap:wrap;gap:8px;margin:14px 0 20px;padding:14px;border:1px dashed var(--line);border-radius:5px;background:rgba(0,0,0,.2)}
  .chip{font-family:'Bebas Neue';letter-spacing:1.5px;font-size:15px;padding:8px 14px;border-radius:3px;cursor:pointer;
    border:1px solid currentColor;background:rgba(255,255,255,.04);transition:.18s;user-select:none}
  .chip:hover{transform:translateY(-2px)}
  .chip.picked{box-shadow:0 0 0 2px var(--ink), 0 0 14px currentColor;transform:translateY(-2px)}
  .chip.placed{opacity:.2;pointer-events:none;text-decoration:line-through}
  .sent{display:flex;gap:12px;align-items:stretch;border:1px solid var(--line);border-radius:5px;margin:9px 0;
    background:var(--panel);overflow:hidden;cursor:pointer;transition:.18s}
  .sent:hover{border-color:var(--gold-dim)}
  .sent .slot{flex:0 0 64px;display:grid;place-items:center;background:rgba(0,0,0,.25);border-right:1px solid var(--line);
    font-family:'Bebas Neue';font-size:10px;letter-spacing:1px;text-align:center;color:var(--muted);padding:4px;transition:.25s}
  .sent .txt{padding:12px 14px;font-family:'Special Elite',serif;font-size:13.5px;line-height:1.6}
  .sent.filled .slot{color:#0c0a09;font-size:13px}
  .sent.lock{cursor:default}
  .sent.lock .slot::after{content:" ✓"}
  .sent.shake{animation:shake .4s}
  @keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-7px)}75%{transform:translateX(7px)}}

  /* fragment assembler */
  .assembler{position:fixed;left:0;right:0;bottom:0;z-index:60;background:linear-gradient(0deg,var(--bg),rgba(12,10,9,.85));
    border-top:1px solid var(--line);padding:12px 16px;backdrop-filter:blur(6px)}
  .assembler .inner{max-width:860px;margin:0 auto;display:flex;align-items:center;gap:10px;justify-content:center;flex-wrap:wrap}
  .assembler small{font-size:9px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;width:100%;text-align:center;margin-bottom:4px}
  .frag{font-family:'Space Mono';font-weight:700;letter-spacing:3px;font-size:18px;border:1px dashed var(--gold-dim);
    color:var(--gold-dim);padding:6px 16px;border-radius:3px;min-width:80px;text-align:center;transition:.4s}
  .frag.on{border-style:solid;border-color:var(--cyan);color:var(--cyan);background:rgba(52,211,166,.08);box-shadow:0 0 16px rgba(52,211,166,.25)}
  .frag .dash{color:var(--muted)}

  /* ---- escape ---- */
  .vaultdoor{width:180px;height:180px;margin:10px auto 0;position:relative}
  .vaultdoor .disc{position:absolute;inset:0;border-radius:50%;border:8px solid var(--gold-dim);
    background:radial-gradient(circle at 35% 30%,#2a2118,#0e0b08);box-shadow:0 0 40px rgba(244,183,64,.25)}
  .vaultdoor.open .disc{animation:spinopen 1.4s cubic-bezier(.7,0,.2,1) forwards}
  @keyframes spinopen{to{transform:rotate(420deg) scale(.0);opacity:0}}
  .vaultdoor .spokes{position:absolute;inset:34px;border-radius:50%;border:4px solid var(--gold);opacity:.6}
  .vaultdoor.open .spokes{animation:spinopen 1.4s .05s cubic-bezier(.7,0,.2,1) forwards}
  .vaultdoor .glow{position:absolute;inset:0;border-radius:50%;opacity:0}
  .vaultdoor.open .glow{background:radial-gradient(circle,rgba(244,183,64,.6),transparent 70%);animation:burst 1.4s .6s ease forwards}
  @keyframes burst{0%{opacity:0;transform:scale(.3)}40%{opacity:1}100%{opacity:0;transform:scale(2.4)}}

  .badge{width:128px;height:128px;margin:6px auto 14px;border-radius:50%;display:grid;place-items:center;
    background:radial-gradient(circle at 35% 30%,#2a2118,#120d08);border:3px solid var(--gold);
    box-shadow:0 0 30px rgba(244,183,64,.4), inset 0 0 22px rgba(244,183,64,.15);font-size:54px;
    animation:pop .6s .9s both}
  @keyframes pop{0%{transform:scale(0) rotate(-30deg);opacity:0}70%{transform:scale(1.15)}100%{transform:scale(1);opacity:1}}
  .breakdown{border:1px solid var(--line);border-radius:5px;margin-top:18px;overflow:hidden}
  .breakdown div{display:flex;justify-content:space-between;padding:9px 16px;font-size:13px;border-bottom:1px solid var(--line)}
  .breakdown div:last-child{border-bottom:0;background:rgba(244,183,64,.07)}
  .breakdown b{color:var(--gold)}
  .center{text-align:center}
  .toast{position:fixed;top:80px;left:50%;transform:translateX(-50%);background:var(--panel2);border:1px solid var(--gold-dim);
    color:var(--gold-soft);padding:10px 18px;border-radius:4px;font-size:12.5px;z-index:200;opacity:0;transition:.3s;pointer-events:none;max-width:90%;text-align:center}
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
  .feedline{font-size:13px;margin-top:12px;min-height:20px}
  .feedline.ok{color:var(--cyan)} .feedline.no{color:var(--red)}
</style>
</head>
<body>
<div class="wrap">

  <!-- HUD -->
  <div class="hud">
    <div class="brandmark">
      <div class="seal">🔎</div>
      <div><b>THE ABSTRACT HEIST</b><span>Classified · Level 2 Op</span></div>
    </div>
    <div class="stats">
      <div class="stat"><label>XP</label><b id="xp">0</b></div>
      <div class="stat"><label>Rank</label><b id="rankTag">—</b></div>
    </div>
  </div>

  <!-- progress rail -->
  <div class="rail" id="rail">
    <div class="node" data-n="1"><div class="ring">🔒</div><small>Skim</small></div>
    <div class="railbar"></div>
    <div class="node" data-n="2"><div class="ring">🔒</div><small>Scan</small></div>
    <div class="railbar"></div>
    <div class="node" data-n="3"><div class="ring">🔒</div><small>Infer</small></div>
    <div class="railbar"></div>
    <div class="node" data-n="4"><div class="ring">🏁</div><small>Escape</small></div>
  </div>

  <!-- ===== INTRO ===== -->
  <section class="screen show" id="s-intro">
    <div class="card">
      <div class="vlabel">Mission Briefing</div>
      <h1>Crack The Vault</h1>
      <p class="case">You're an elite codebreaker. Locked inside this research vault is the <em>meaning</em> of a top-secret abstract — but you only have your wits and the clock. Your task is <em>not</em> to translate every word. Skim for the big picture. Scan for the rhetorical moves. Infer what was never said. Crack three locks, assemble the master code, and escape.</p>
      <p class="muted" style="margin-top:14px">⏱ Vault 1 is timed (45s). Hints cost <b style="color:var(--gold-soft)">−10 XP</b>. Max take: <b style="color:var(--gold-soft)">180 XP</b>.</p>
      <div class="row"><button class="btn" onclick="go(1)">▸ Begin the Heist</button></div>
    </div>
  </section>

  <!-- ===== VAULT 1 — SKIM ===== -->
  <section class="screen" id="s-1">
    <div class="card">
      <div class="vlabel">Vault 01 · 🟦 The Skim Vault</div>
      <h2>Read fast. Lock it. Recall.</h2>
      <p class="muted">Skim the whole abstract in one pass. Lock the vault <b style="color:var(--gold-soft)">before the clock runs out</b> for a +20 time bonus — then answer from the big picture.</p>

      <div class="timer">
        <div class="ringwrap">
          <svg width="84" height="84"><circle cx="42" cy="42" r="36" stroke="#3a2f23" stroke-width="6" fill="none"/>
          <circle id="ring" cx="42" cy="42" r="36" stroke="#f4b740" stroke-width="6" fill="none" stroke-linecap="round" stroke-dasharray="226" stroke-dashoffset="0"/></svg>
          <div class="num" id="tnum">45</div>
        </div>
        <button class="btn ghost" id="lockBtn" onclick="lockVault1()">🔒 Lock the Vault & Answer</button>
      </div>

      <div class="abstract" id="abstract">
        The presence of microplastics in urban drinking water has emerged as a growing environmental and public health concern. Although several studies have reported microplastic particles in tap and bottled water, detection methods remain inconsistent, making it difficult to compare findings across regions. This study evaluates the prevalence, sources, and analytical techniques used to measure microplastic contamination. We systematically reviewed 62 peer-reviewed articles published between 2015 and 2023. Microplastics were detected in 81% of sampled water systems, with polyethylene and polypropylene being the most common polymers. These findings highlight an urgent need for standardized detection methods and suggest that current regulatory frameworks may underestimate human exposure.
      </div>
      <div class="lockedstamp" id="stamp">VAULT LOCKED</div>

      <div id="v1questions" style="display:none">
        <div class="q" data-correct="b">
          <p><b>Q1 · Topic.</b> What is the general subject?</p>
          <button class="opt" data-k="a">Plastic recycling technologies</button>
          <button class="opt" data-k="b">Microplastic contamination in drinking water</button>
          <button class="opt" data-k="c">Ocean pollution from fishing nets</button>
          <button class="opt" data-k="d">Bottled-water marketing strategy</button>
        </div>
        <div class="q" data-correct="b">
          <p><b>Q2 · Problem.</b> What gap is being addressed?</p>
          <button class="opt" data-k="a">Drinking water has become too expensive</button>
          <button class="opt" data-k="b">Detection methods are inconsistent across studies</button>
          <button class="opt" data-k="c">No studies on microplastics exist yet</button>
          <button class="opt" data-k="d">Plastics are banned in most countries</button>
        </div>
        <div class="q" data-correct="a">
          <p><b>Q3 · Discipline.</b> Which field does it belong to?</p>
          <button class="opt" data-k="a">Environmental / public-health science</button>
          <button class="opt" data-k="b">Astrophysics</button>
          <button class="opt" data-k="c">Medieval history</button>
          <button class="opt" data-k="d">Brand marketing</button>
        </div>
        <div class="q" data-correct="b">
          <p><b>Q4 · Significance.</b> Why does it matter?</p>
          <button class="opt" data-k="a">It proves bottled water is completely safe</button>
          <button class="opt" data-k="b">Current regulations may underestimate human exposure</button>
          <button class="opt" data-k="c">It discovers a brand-new polymer</button>
          <button class="opt" data-k="d">It lowers the cost of water treatment</button>
        </div>
        <div class="feedline" id="v1feed"></div>
        <div class="row">
          <button class="btn" id="v1submit" onclick="checkV1()">Submit Answers</button>
          <button class="btn hint" onclick="hint(1)">💡 Hint (−10)</button>
          <button class="btn" id="v1next" style="display:none" onclick="go(2)">▸ Fragment secured — Vault 02</button>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== VAULT 2 — SCAN ===== -->
  <section class="screen" id="s-2">
    <div class="card">
      <div class="vlabel">Vault 02 · 🟩 The Scan Vault</div>
      <h2>Tag the rhetorical moves.</h2>
      <p class="muted">Tap a coloured <b style="color:var(--gold-soft)">move</b>, then tap the sentence it belongs to. Each move is used once. Land <b style="color:var(--gold-soft)">5 of 6</b> to crack the lock — get all 6 for full marks (+15 each).</p>

      <div class="tray" id="tray"></div>
      <div id="sentences"></div>

      <div class="feedline" id="v2feed"></div>
      <div class="row">
        <button class="btn" id="v2check" onclick="checkV2()" disabled>Check the Vault</button>
        <button class="btn hint" onclick="hint(2)">💡 Hint (−10)</button>
        <button class="btn" id="v2next" style="display:none" onclick="go(3)">▸ Fragment secured — Vault 03</button>
      </div>
    </div>
  </section>

  <!-- ===== VAULT 3 — INFER ===== -->
  <section class="screen" id="s-3">
    <div class="card">
      <div class="vlabel">Vault 03 · 🟥 The Infer Vault — Final Lock</div>
      <h2>Read between the lines.</h2>
      <p class="case">The author never names who should worry most about these findings — <em>but the vault knows.</em> Which inference is best supported, though it is never directly stated?</p>

      <div class="q" id="inferQ" data-correct="b" style="border-top:0;margin-top:18px">
        <button class="opt" data-k="a">Microplastics are harmless precisely because they are so common.</button>
        <button class="opt" data-k="b">Regulators and water utilities should adopt one standardized detection method before exposure can be judged accurately.</button>
        <button class="opt" data-k="c">People should stop drinking tap water immediately.</button>
        <button class="opt" data-k="d">Polyethylene is the only polymer that poses any risk.</button>
      </div>

      <p class="muted" style="margin-top:6px">Optional field notes — justify your pick in one line (not graded, but real detectives show their reasoning):</p>
      <textarea id="justify" rows="2" style="width:100%;margin-top:8px;background:var(--panel);border:1px solid var(--line);color:var(--ink);
        font-family:'Special Elite',serif;border-radius:4px;padding:10px;resize:vertical" placeholder="It's supported because..."></textarea>

      <div class="feedline" id="v3feed"></div>
      <div class="row">
        <button class="btn" id="v3submit" onclick="checkV3()">Crack the Final Lock</button>
        <button class="btn hint" onclick="hint(3)">💡 Hint (−10)</button>
        <button class="btn" id="v3next" style="display:none" onclick="go(4)">▸ Assemble the master code</button>
      </div>
    </div>
  </section>

  <!-- ===== ESCAPE ===== -->
  <section class="screen" id="s-4">
    <div class="card center">
      <div class="vaultdoor" id="door">
        <div class="glow"></div><div class="disc"></div><div class="spokes"></div>
      </div>
      <div class="vlabel" style="margin-top:8px">Master Code Accepted</div>
      <h1 style="font-size:clamp(34px,8vw,64px)">You're Out.</h1>
      <div class="badge">🔎</div>
      <div class="vlabel">Badge Unlocked</div>
      <h2 style="color:var(--gold)">Abstract Detective</h2>
      <p id="rankLine" class="case" style="margin-top:8px"></p>

      <div class="breakdown" id="breakdown"></div>
      <div class="row" style="justify-content:center">
        <button class="btn ghost" onclick="resetGame()">↻ Run it again</button>
      </div>
    </div>
  </section>

</div>

<!-- fragment assembler -->
<div class="assembler">
  <div class="inner">
    <small>Master Code Assembler</small>
    <span class="frag" id="fragA">A</span>
    <span class="frag dash">—</span>
    <span class="frag" id="fragB">B</span>
    <span class="frag dash">—</span>
    <span class="frag" id="fragC">C</span>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
/* ---------------- state ---------------- */
let xp = 0;
let v1Awarded = {}, v1Pass=false, v1TimeBonus=false, v1bonusGiven=false;
let v2Pass=false, v2Awarded={};
let v3Pass=false;
let timer=null, timeLeft=45, locked=false;
const hintsUsed={1:false,2:false,3:false};

const RANKS=[
  {min:170,name:'Master Spy 🥇'},
  {min:130,name:'Field Agent 🥈'},
  {min:90, name:'Rookie Reader 🥉'},
  {min:0,  name:'In Training'}
];
function rankFor(s){return RANKS.find(r=>s>=r.min).name;}

function addXP(n){
  xp=Math.max(0,xp+n);
  document.getElementById('xp').textContent=xp;
  document.getElementById('rankTag').textContent=rankFor(xp).split(' ')[0]+(rankFor(xp).match(/[🥇🥈🥉]/)?' '+rankFor(xp).match(/[🥇🥈🥉]/)[0]:'');
}
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(t._t);t._t=setTimeout(()=>t.classList.remove('show'),2200);}

/* ---------------- navigation ---------------- */
function go(n){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('show'));
  const map={1:'s-1',2:'s-2',3:'s-3',4:'s-4',intro:'s-intro'};
  document.getElementById(map[n]).classList.add('show');
  // rail states
  document.querySelectorAll('.node').forEach(nd=>{
    const k=+nd.dataset.n; nd.classList.remove('active','done');
    if(k<n) nd.classList.add('done');
    if(k===n) nd.classList.add('active');
  });
  if(n===1) startTimer();
  if(n===2) buildV2();
  if(n===4) escapeSeq();
  window.scrollTo({top:0,behavior:'smooth'});
}

/* ---------------- VAULT 1 ---------------- */
function startTimer(){
  if(timer) return;
  const ring=document.getElementById('ring'), num=document.getElementById('tnum');
  const total=45, C=226;
  timer=setInterval(()=>{
    timeLeft--;
    num.textContent=timeLeft;
    ring.style.strokeDashoffset = C*(1-timeLeft/total);
    if(timeLeft<=10) ring.style.stroke='var(--red)', num.style.color='var(--red)';
    if(timeLeft<=0){clearInterval(timer);timer=null;num.textContent=0;lockVault1(true);}
  },1000);
}
function lockVault1(auto){
  if(locked) return; locked=true;
  if(timer){clearInterval(timer);timer=null;}
  if(!auto && timeLeft>0){v1TimeBonus=true;}
  document.getElementById('abstract').classList.add('locked');
  document.getElementById('stamp').classList.add('show');
  document.getElementById('lockBtn').disabled=true;
  document.getElementById('v1questions').style.display='block';
  toast(v1TimeBonus?'Locked early — +20 time bonus banked on a pass!':'Vault sealed. Recall from the big picture.');
}
/* option selection for any .q */
document.addEventListener('click',e=>{
  const opt=e.target.closest('.opt'); if(!opt) return;
  const q=opt.closest('.q'); if(q.classList.contains('answered')) return;
  q.querySelectorAll('.opt').forEach(o=>o.classList.remove('sel'));
  opt.classList.add('sel'); q.dataset.pick=opt.dataset.k;
});
function checkV1(){
  const qs=[...document.querySelectorAll('#v1questions .q')];
  if(qs.some(q=>!q.dataset.pick)){toast('Answer all four before submitting.');return;}
  let correct=0;
  qs.forEach((q,i)=>{
    const pick=q.dataset.pick, ok=pick===q.dataset.correct;
    const sel=q.querySelector('.opt.sel');
    q.querySelectorAll('.opt').forEach(o=>o.classList.remove('correct','wrong'));
    sel.classList.add(ok?'correct':'wrong');
    if(ok){
      correct++;
      if(!v1Awarded[i]){v1Awarded[i]=true;addXP(10);}
    }
  });
  const feed=document.getElementById('v1feed');
  if(correct>=3){
    if(v1TimeBonus && !v1bonusGiven){v1bonusGiven=true;addXP(20);}
    v1Pass=true;
    feed.className='feedline ok'; feed.textContent=`✓ ${correct}/4 correct. Code Fragment A decrypted: "WATER".`;
    setFrag('A','WATER');
    document.getElementById('v1submit').style.display='none';
    document.getElementById('v1next').style.display='inline-block';
    qs.forEach(q=>q.classList.add('answered'));
  }else{
    feed.className='feedline no'; feed.textContent=`✗ Only ${correct}/4. The lock holds — re-read the dimmed text and try the misses again.`;
  }
}

/* ---------------- VAULT 2 ---------------- */
const MOVES=[
  {key:'territory',  name:'Territory',    color:'var(--m-territory)'},
  {key:'niche',      name:'Niche',        color:'var(--m-niche)'},
  {key:'purpose',    name:'Purpose',      color:'var(--m-purpose)'},
  {key:'method',     name:'Method',       color:'var(--m-method)'},
  {key:'results',    name:'Results',      color:'var(--m-results)'},
  {key:'implications',name:'Implications',color:'var(--m-implications)'}
];
const SENTENCES=[
  {id:'s1',correct:'territory',  txt:'The presence of microplastics in urban drinking water has emerged as a growing environmental and public-health concern.'},
  {id:'s2',correct:'niche',      txt:'Although studies have reported particles in water, detection methods remain inconsistent, making findings hard to compare across regions.'},
  {id:'s3',correct:'purpose',    txt:'This study evaluates the prevalence, sources, and analytical techniques used to measure microplastic contamination.'},
  {id:'s4',correct:'method',     txt:'We systematically reviewed 62 peer-reviewed articles published between 2015 and 2023.'},
  {id:'s5',correct:'results',    txt:'Microplastics were detected in 81% of sampled water systems, with polyethylene and polypropylene most common.'},
  {id:'s6',correct:'implications',txt:'These findings highlight an urgent need for standardized detection and suggest regulations may underestimate human exposure.'}
];
let pickedMove=null, assign={}; // sentenceId -> moveKey
let v2Built=false;
function shuffle(a){a=a.slice();for(let i=a.length-1;i>0;i--){const j=Math.random()*(i+1)|0;[a[i],a[j]]=[a[j],a[i]];}return a;}
function moveByKey(k){return MOVES.find(m=>m.key===k);}

function buildV2(){
  if(v2Built) return; v2Built=true;
  const tray=document.getElementById('tray');
  shuffle(MOVES).forEach(m=>{
    const c=document.createElement('div');
    c.className='chip'; c.style.color=m.color; c.dataset.key=m.key; c.textContent=m.name;
    c.onclick=()=>pickMove(m.key,c);
    tray.appendChild(c);
  });
  const box=document.getElementById('sentences');
  shuffle(SENTENCES).forEach((s,i)=>{
    const row=document.createElement('div');
    row.className='sent'; row.dataset.id=s.id; row.dataset.correct=s.correct;
    row.innerHTML=`<div class="slot">DROP<br>MOVE</div><div class="txt">${s.txt}</div>`;
    row.onclick=()=>dropOnSentence(s.id,row);
    box.appendChild(row);
  });
}
function pickMove(key,chip){
  if(chip.classList.contains('placed')) return;
  if(pickedMove===key){pickedMove=null;chip.classList.remove('picked');return;}
  document.querySelectorAll('.chip').forEach(c=>c.classList.remove('picked'));
  pickedMove=key; chip.classList.add('picked');
}
function dropOnSentence(sid,row){
  if(row.classList.contains('lock')) return;
  // if no move picked but slot filled -> clear it back to tray
  if(!pickedMove){
    if(assign[sid]) returnChip(assign[sid]), clearRow(sid,row);
    return;
  }
  // if slot already had a move, return it first
  if(assign[sid]) returnChip(assign[sid]);
  // place
  assign[sid]=pickedMove;
  const m=moveByKey(pickedMove);
  row.classList.add('filled');
  row.querySelector('.slot').style.background=m.color;
  row.querySelector('.slot').innerHTML=m.name;
  const chip=[...document.querySelectorAll('.chip')].find(c=>c.dataset.key===pickedMove);
  chip.classList.add('placed'); chip.classList.remove('picked');
  pickedMove=null;
  refreshV2Btn();
}
function clearRow(sid,row){
  delete assign[sid];
  row.classList.remove('filled');
  row.querySelector('.slot').style.background='';
  row.querySelector('.slot').innerHTML='DROP<br>MOVE';
  refreshV2Btn();
}
function returnChip(key){
  const chip=[...document.querySelectorAll('.chip')].find(c=>c.dataset.key===key);
  if(chip) chip.classList.remove('placed');
}
function refreshV2Btn(){
  document.getElementById('v2check').disabled = Object.keys(assign).length<6;
}
function checkV2(){
  const rows=[...document.querySelectorAll('.sent')];
  let correct=0;
  rows.forEach(row=>{
    const sid=row.dataset.id;
    if(row.classList.contains('lock')){correct++;return;}
    if(assign[sid]===row.dataset.correct){
      row.classList.add('lock');
      if(!v2Awarded[sid]){v2Awarded[sid]=true;addXP(15);}
      correct++;
    }else{
      // wrong -> shake, release chip back, clear
      row.classList.add('shake');
      setTimeout(()=>row.classList.remove('shake'),420);
      if(assign[sid]) returnChip(assign[sid]);
      clearRow(sid,row);
    }
  });
  const feed=document.getElementById('v2feed');
  if(correct>=5){
    v2Pass=true;
    feed.className='feedline ok';
    feed.textContent = correct===6
      ? '✓ Flawless map — all 6 moves tagged. Fragment B decrypted: "81".'
      : `✓ ${correct}/6 — enough to crack it. Fragment B: "81". (Fix the last one for +15 if you like, then proceed.)`;
    setFrag('B','81');
    document.getElementById('v2next').style.display='inline-block';
    if(correct===6){document.getElementById('v2check').disabled=true;}
  }else{
    feed.className='feedline no';
    feed.textContent=`✗ ${correct}/6 correct. The wrong tags dropped back to the tray — re-place and check again.`;
  }
}

/* ---------------- VAULT 3 ---------------- */
function checkV3(){
  const q=document.getElementById('inferQ');
  if(!q.dataset.pick){toast('Choose the best-supported inference.');return;}
  const ok=q.dataset.pick===q.dataset.correct;
  const sel=q.querySelector('.opt.sel');
  q.querySelectorAll('.opt').forEach(o=>o.classList.remove('correct','wrong'));
  sel.classList.add(ok?'correct':'wrong');
  const feed=document.getElementById('v3feed');
  if(ok){
    v3Pass=true; addXP(30);
    q.querySelector('.opt[data-k="b"]').classList.add('correct');
    q.classList.add('answered');
    feed.className='feedline ok';
    feed.textContent='✓ Valid inference — supported but never stated. Final fragment C: "SAFE".';
    setFrag('C','SAFE');
    document.getElementById('v3submit').style.display='none';
    document.getElementById('v3next').style.display='inline-block';
  }else{
    feed.className='feedline no';
    feed.textContent='✗ That one is either contradicted by the text or an over-reach. A good inference is supported yet unstated — and avoids extremes. Try again.';
  }
}

/* ---------------- fragments ---------------- */
function setFrag(which,val){
  const el=document.getElementById('frag'+which);
  el.textContent=val; el.classList.add('on');
}

/* ---------------- hints ---------------- */
const HINTS={
  1:'Skim the FIRST sentence for the topic, and the LAST for why it matters. Ignore the numbers.',
  2:'Niche owns "although / inconsistent / hard to compare." Implications owns "urgent need / underestimate." Method is the one with the count of articles.',
  3:'Reject anything with "harmless," "stop immediately," or "only." A good inference is modest, supported, and unstated.'
};
function hint(v){
  if(!hintsUsed[v]){hintsUsed[v]=true;addXP(-10);toast('Hint unlocked (−10 XP): '+HINTS[v]);}
  else{toast('Hint: '+HINTS[v]);}
}

/* ---------------- ESCAPE ---------------- */
function escapeSeq(){
  setTimeout(()=>document.getElementById('door').classList.add('open'),250);
  const rank=rankFor(xp);
  document.getElementById('rankLine').innerHTML=
    `Master code <b style="color:var(--cyan)">WATER-81-SAFE</b> accepted. Final haul: <b style="color:var(--gold)">${xp} XP</b> — rank: <b style="color:var(--gold)">${rank}</b>.`;
  const rows=[
    ['Skim Vault (recall + time bonus)', sumSkim()],
    ['Scan Vault (rhetorical moves)', sumScan()],
    ['Infer Vault (inference)', v3Pass?30:0],
    ['Hints used', '−'+(Object.values(hintsUsed).filter(Boolean).length*10)+' XP'],
    ['TOTAL XP', xp+' XP']
  ];
  document.getElementById('breakdown').innerHTML=rows.map(r=>`<div><span>${r[0]}</span><b>${typeof r[1]==='number'?r[1]+' XP':r[1]}</b></div>`).join('');
  /* Signal the parent Journey page so completing the Heist unlocks Level 6 (warp to the Boss) */
  try{if(window.parent&&window.parent!==window){window.parent.postMessage({type:'heist-complete',xp:xp,rank:rankFor(xp)},'*');}}catch(e){}
}
function sumSkim(){let n=Object.keys(v1Awarded).length*10; if(v1bonusGiven)n+=20; return n;}
function sumScan(){return Object.keys(v2Awarded).length*15;}

/* ---------------- reset ---------------- */
function resetGame(){
  xp=0;v1Awarded={};v1Pass=v1TimeBonus=v1bonusGiven=false;
  v2Pass=false;v2Awarded={};v3Pass=false;
  timer&&clearInterval(timer);timer=null;timeLeft=45;locked=false;
  hintsUsed[1]=hintsUsed[2]=hintsUsed[3]=false;
  pickedMove=null;assign={};v2Built=false;
  // reset DOM
  document.getElementById('xp').textContent='0';
  document.getElementById('rankTag').textContent='—';
  document.getElementById('tnum').textContent='45';document.getElementById('tnum').style.color='var(--gold)';
  document.getElementById('ring').style.strokeDashoffset='0';document.getElementById('ring').style.stroke='var(--gold)';
  document.getElementById('abstract').classList.remove('locked');
  document.getElementById('stamp').classList.remove('show');
  document.getElementById('lockBtn').disabled=false;
  document.getElementById('v1questions').style.display='none';
  document.getElementById('v1submit').style.display='inline-block';
  document.getElementById('v1next').style.display='none';
  document.getElementById('v1feed').textContent='';
  document.getElementById('v2feed').textContent='';
  document.getElementById('v2next').style.display='none';
  document.getElementById('v3submit').style.display='inline-block';
  document.getElementById('v3next').style.display='none';
  document.getElementById('v3feed').textContent='';
  document.getElementById('justify').value='';
  document.getElementById('tray').innerHTML='';
  document.getElementById('sentences').innerHTML='';
  document.getElementById('door').classList.remove('open');
  ['A','B','C'].forEach(f=>{const e=document.getElementById('frag'+f);e.textContent=f;e.classList.remove('on');});
  document.querySelectorAll('.q').forEach(q=>{q.classList.remove('answered');delete q.dataset.pick;
    q.querySelectorAll('.opt').forEach(o=>o.classList.remove('sel','correct','wrong'));});
  go('intro');
}
</script>

<script>
function openHeist() {
  // Only allow opening the Heist if the bonus vault is unlocked (Level 3 completed → completedLevels >= 4)
  try {
    if (typeof completedLevels !== 'undefined' && completedLevels < 4) {
      alert('Complete Level 3 to unlock the Abstract Heist.');
      return;
    }
  } catch (e) {
    // fail-safe: if state is missing, prevent navigation
    alert('Complete Level 3 to unlock the Abstract Heist.');
    return;
  }

  const modal = document.getElementById('heist-modal');
  const iframe = document.getElementById('heist-frame');
  if (!iframe.srcdoc) {
    const raw = document.getElementById('heist-source').textContent;
    iframe.srcdoc = raw.replaceAll('<\\/script>', '</script>');
  }
  modal.classList.add('open');
  document.body.classList.add('heist-open');
}
function closeHeist() {
  document.getElementById('heist-modal').classList.remove('open');
  document.body.classList.remove('heist-open');
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape' && document.getElementById('heist-modal').classList.contains('open')) closeHeist();
});
</script>
