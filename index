  /* Generalised: any level can be completed and unlocks the next one. */
  function completeLevel(id) {
    if (id < 6) {
      completedLevels = Math.max(completedLevels, id + 1);
      updateProgress();
      alert(`🎉 Level ${id} completed! Level ${id + 1} is now unlocked.`);
    } else {
      completedLevels = 6;
      updateProgress();
      alert(`🏆 Journey complete! You've earned the Diamond Crown of Publication.`);
    }
    document.getElementById('detail-panel').classList.add('hidden');
    renderLevels();
  }

  function toggleOverview() {
    document.getElementById('overview-section').classList.toggle('hidden');
  }

  /* Fixed XP counter: sums actual XP for each unlocked level. */
  function updateProgress() {
    const percent = Math.min((completedLevels / 6) * 100, 100);
    document.getElementById('progress-bar').style.width = percent + '%';
    let xp = 0;
    for (let i = 0; i < completedLevels && i < levels.length; i++) xp += levels[i].xp;
    document.getElementById('progress-text').innerHTML = `Level ${completedLevels} of 6 • ${xp} XP`;
  }

  /**
   * Open the Heist in the modal iframe via its GitHub Pages URL.
   * Using iframe src (not srcdoc) preserves the parent ⇄ child relationship,
   * so window.parent.postMessage from the Heist reaches onHeistComplete here,
   * which is what enables the warp to Level 6. New tabs cannot do this.
   * Only fires if Level 3 has been completed.
   */
  const VAULT_URL = "https://profeanaeslavaedtech.github.io/escaperoom/";
  function openVaultModal() {
    if (typeof completedLevels === 'undefined' || completedLevels < 4) {
      alert('Complete Level 3 first to unlock the Abstract Heist.');
      return;
    }
    const modal = document.getElementById('heist-modal');
    const iframe = document.getElementById('heist-frame');
    if (iframe.src !== VAULT_URL) iframe.src = VAULT_URL;
    modal.classList.add('open');
    document.body.classList.add('heist-open');
  }

  /**
   * Manual unlock fallback — for learners who played the Heist in another window/device
   * and need to register completion in the journey. Triggers the same handler as postMessage.
   */
  function manualHeistUnlock() {
    if (heistCompleted) return;
    if (!confirm('Confirm: you completed the Abstract Heist in another window and want to unlock Levels 4, 5 and 6 now?')) return;
    onHeistComplete(0, 'Manual unlock');
  }

  // Initialize
  renderLevels();
  updateProgress();
</script>

